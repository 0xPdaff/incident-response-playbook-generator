# Incident Response Playbook Generator — Environment Variables
# Copy this file to .env and fill in your API keys.

# ---- LLM Provider API Keys ----
# At least one provider must have a valid key.
# The default provider is set in config/model_config.yaml.

# OpenAI (default)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Deepseek
DEEPSEEK_API_KEY=

# Minimax
MINIMAX_API_KEY=

# Kimi (Moonshot)
KIMI_API_KEY=

# Qwen (Alibaba)
QWEN_API_KEY=

# GLM (Zhipu AI)
GLM_API_KEY=

# Ollama runs locally — no key needed
# OLLAMA_API_BASE=http://localhost:11434

# ---- Application Settings ----
# Override default provider (optional)
# DEFAULT_PROVIDER=openai

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API server port
API_PORT=8000
